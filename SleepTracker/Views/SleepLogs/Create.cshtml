@model SleepTracker.Models.SleepLog

@{
    ViewData["Title"] = "Create";
}

<h1>Create Sleep Log</h1>

<!-- Form for creating a new sleep log -->
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="SleepStart" class="form-label"></label>
        <input asp-for="SleepStart" class="form-control" type="datetime-local" />
        <span asp-validation-for="SleepStart" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SleepEnd" class="form-label"></label>
        <input asp-for="SleepEnd" class="form-control" type="datetime-local" />
        <span asp-validation-for="SleepEnd" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Quality" class="form-label"></label>
        <input asp-for="Quality" class="form-control" min="1" max="5" />
        <span asp-validation-for="Quality" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="UserId" class="form-label">User</label>
        <select asp-for="UserId" class="form-control" asp-items="ViewBag.Users">
            <option value="">-- Select User --</option>
        </select>
        <span asp-validation-for="UserId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}