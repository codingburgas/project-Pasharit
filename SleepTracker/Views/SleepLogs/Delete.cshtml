@model SleepTracker.Models.SleepLog

@{
    ViewData["Title"] = "Delete Sleep Log";
}

<h1>Delete Sleep Log</h1>

<h3>Are you sure you want to delete this?</h3>

<div class="card p-3">
    <p><strong>Sleep Start:</strong> @Model.SleepStart.ToString("dd.MM.yyyy HH:mm")</p>
    <p><strong>Sleep End:</strong> @Model.SleepEnd.ToString("dd.MM.yyyy HH:mm")</p>
    <p><strong>Quality:</strong> @Model.Quality</p>
    <p><strong>User:</strong> @Model.User?.Name</p>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>