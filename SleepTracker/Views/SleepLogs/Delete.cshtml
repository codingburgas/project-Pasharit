@model SleepTracker.Models.SleepLog

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete Sleep Log</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
    <p><strong>Sleep Start:</strong> @Model.SleepStart</p>
    <p><strong>Sleep End:</strong> @Model.SleepEnd</p>
    <p><strong>Quality:</strong> @Model.Quality</p>
    <p><strong>User:</strong> @Model.User?.Name</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>