@model SleepTracker.Models.SleepLog

@{
    ViewData["Title"] = "Sleep Log Details";
}

<h1>Sleep Log Details</h1>

<div class="card p-3">
    <p><strong>Sleep Start:</strong> @Model.SleepStart.ToString("dd.MM.yyyy HH:mm")</p>
    <p><strong>Sleep End:</strong> @Model.SleepEnd.ToString("dd.MM.yyyy HH:mm")</p>
    <p><strong>Quality:</strong> @Model.Quality</p>
    <p><strong>Duration:</strong> @Model.DurationHours.ToString("0.00") hours</p>
    <p><strong>User:</strong> @Model.User?.Name</p>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Back</a>