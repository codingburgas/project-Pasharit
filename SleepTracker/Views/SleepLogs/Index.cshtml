@model IEnumerable<SleepTracker.DTOs.SleepLogDTO>

@{
    ViewData["Title"] = "Sleep Logs";
    bool isAdmin = ViewBag.IsAdmin != null && (bool)ViewBag.IsAdmin;
}

<h1>Sleep Logs</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Sleep Log</a>
</p>

@if (isAdmin)
{
    <p class="text-success"><strong>Current role:</strong> Admin</p>
}
else
{
    <p class="text-secondary"><strong>Current role:</strong> User</p>
}

<!-- Displays all sleep logs with role-based actions -->
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Sleep Start</th>
            <th>Sleep End</th>
            <th>Quality</th>
            <th>Duration (hours)</th>
            <th>User</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.SleepStart.ToString("dd.MM.yyyy HH:mm")</td>
            <td>@item.SleepEnd.ToString("dd.MM.yyyy HH:mm")</td>
            <td>
                @for (int i = 0; i < item.Quality; i++)
                {
                    <span style="color:gold; font-size:20px;">★</span>
                }
            </td>
            <td>@item.DurationHours.ToString("0.00")</td>
            <td>@item.UserName</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                @if (isAdmin)
                {
                    <text> | </text>
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>